DB_HOST=192.168.x.x
DB_PORT=3306
DB_USER=your_db_user
DB_PASS=your_db_password
DB_NAME=your_db_name
SECRETTOKEN=your_jwt_secret_token

# Port berbeda dari backend utama (4001)
PORT=4002

NODE_ENV=production
DB_AES_KEY_USER=nur
DB_AES_KEY_PASS=windi

# URL webapps
HOST_WEB=http://192.168.x.x
HOST_WEB_PORT=80
HOST_WEB_ROOT=webapps

# Redis (untuk rate limiter) bisa di command untuk nonaktifkan
REDIS_ENABLED=false
REDIS_HOST=192.168.x.x
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_PASS=your_redis_password

# Allowed origins untuk Flutter (opsional - emulator Android pakai 10.0.2.2)
ALLOWED_ORIGINS=http://10.0.2.2:4002,http://192.168.x.x:4002

# Performance
DB_CONNECTION_LIMIT=3
