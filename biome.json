{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      "coverage/**",
      "ecosystem.config.js",
      "data/**",
      "logs/**",
      "*.bak",
      "scratch/**"
    ]
  },
  "formatter": {
    "enabled": true,
    "formatWithErrors": false,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "lf"
  },
  "javascript": {
    "globals": ["Bun"],
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "es5",
      "arrowParentheses": "always"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedVariables": "warn",
        "noUndeclaredVariables": "error",
        "noUnusedImports": "warn"
      },
      "style": {
        "useConst": "error",
        "noVar": "error",
        "useTemplate": "warn",
        "useDefaultParameterLast": "warn",
        "noNonNullAssertion": "off",
        "noParameterAssign": "off",
        "useNumberNamespace": "off"
      },
      "suspicious": {
        "noConsoleLog": "off",
        "noDebugger": "error",
        "noExplicitAny": "off",
        "noAssignInExpressions": "off",
        "noFallthroughSwitchClause": "warn"
      },
      "complexity": {
        "noForEach": "off",
        "noStaticOnlyClass": "off",
        "useFlatMap": "warn",
        "useOptionalChain": "warn"
      },
      "performance": {
        "noAccumulatingSpread": "warn",
        "noDelete": "off"
      },
      "security": {
        "noDangerouslySetInnerHtml": "error"
      }
    }
  },
  "overrides": [
    {
      "include": ["middleware/**"],
      "linter": {
        "rules": {
          "correctness": {
            "noUnusedVariables": "off"
          }
        }
      }
    },
    {
      "include": ["loaders/**"],
      "linter": {
        "rules": {
          "style": {
            "noParameterAssign": "off"
          }
        }
      }
    }
  ]
}
